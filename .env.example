APP_NAME="CadeiraLivre"
APP_ENV=local
APP_DEBUG=true
# Local: http://localhost/... | Produção: https://teu-dominio.com (sem barra final)
APP_URL=http://localhost/cadeira-livre/public

DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cadeira_livre_saas
DB_USERNAME=root
# Sem espaço após o =. Ex.: DB_PASSWORD=secret
DB_PASSWORD=

MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="CadeiraLivre"
MAIL_SMTP_HOST=localhost
MAIL_SMTP_PORT=587
MAIL_SMTP_USER=
MAIL_SMTP_PASS=
MAIL_SMTP_ENCRYPTION=tls
# true = enfileira em outbound_emails; processe com: php scripts/process_mail_queue.php
MAIL_QUEUE=false

# Stripe (opcional): cobrança e webhook /webhooks/stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# WhatsApp opcional (Z-API, Evolution API, etc.)
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=

SESSION_NAME=cadeira_livre_session
SESSION_LIFETIME=120

UPLOAD_MAX_BYTES=2097152
